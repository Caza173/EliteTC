# --- Core ---
NODE_ENV=development
PORT=5000

# --- Database ---
# Postgres connection string. For AWS RDS, include sslmode=require.
# Local dev: postgres://elitetc:elitetc@localhost:5432/elitetc
# RDS:       postgres://USER:PASS@elitetc-db.XXXXX.us-east-1.rds.amazonaws.com:5432/elitetc?sslmode=require
DATABASE_URL=

# Optional: path to a CA bundle (e.g. AWS RDS Global Root). When set, pg
# uses rejectUnauthorized: true with this bundle. The production Docker
# image bakes this in at /etc/ssl/rds-global-bundle.pem.
PG_CA_CERT_PATH=

# --- AWS ---
# Region for SES + Textract + S3. EliteGCI uses us-east-1; keep aligned.
AWS_REGION=us-east-1

# S3 bucket for uploaded transaction documents. Must exist; the app does
# not create it. EliteTC default: elitetc-documents (separate from EliteGCI).
S3_DOCUMENTS_BUCKET=elitetc-documents

# Set to "true" in local dev if you don't have S3 credentials yet.
# OCR + parsing still run, but documents are not persisted to S3.
SKIP_S3_UPLOAD=false

# --- SES ---
# Verified sender identity in SES_REGION. Leave blank to log emails to stdout
# instead of sending (useful for local dev and SES sandbox).
SES_REGION=us-east-1
SES_FROM_EMAIL=

# --- OpenAI ---
# Used for contract field extraction after OCR. Leave blank to skip parsing.
OPENAI_API_KEY=
OPENAI_PARSE_MODEL=gpt-4o-mini

# --- Google OAuth (optional, primary auth in production) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public Google client ID, exposed to the browser bundle for Google
# Identity Services. Must match GOOGLE_CLIENT_ID. Set at build time
# (Vite reads VITE_* vars during `npm run build`).
VITE_GOOGLE_CLIENT_ID=

# Surface the dev-login form on the client login page (local dev only).
# Set to "true" to show the form. The server still enforces ALLOW_DEV_LOGIN
# for the dev-login endpoint itself.
VITE_ALLOW_DEV_LOGIN=false

# --- App ---
# Public base URL used in magic-link emails. Example:
# https://app.elitetc.com
APP_BASE_URL=http://localhost:5000

# Dev-only escape hatch to allow /api/auth/dev-login in production.
# Do NOT set to "true" in real production deploys.
ALLOW_DEV_LOGIN=false
